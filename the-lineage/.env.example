# ---- Required to boot (non-test profiles) ----

# HMAC signing key for JWTs. Must be at least 32 bytes for HS256.
# Generate one with:  openssl rand -base64 48
LINEAGE_JWT_SECRET=change-me-generate-at-least-32-bytes-of-randomness-please

# ---- Optional / tunable ----

LINEAGE_DB_URL=jdbc:postgresql://localhost:5432/lineage
LINEAGE_DB_USER=lineage
LINEAGE_DB_PASSWORD=lineage

LINEAGE_JWT_ACCESS_TTL_MIN=15
LINEAGE_JWT_REFRESH_TTL_DAYS=7
